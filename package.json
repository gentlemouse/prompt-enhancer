{
  "name": "lynx",
  "version": "1.3.9",
  "description": "一键润色优化你的 Prompt，让 AI 更好地理解你的意图",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:debug": "npm run build && node scripts/debug-extension-loading.mjs",
    "verify-apis": "npx tsx scripts/verify-apis.ts",
    "smoke:providers": "npx tsx scripts/provider-smoke.ts",
    "prepare": "husky",
    "package": "npm run build && zip -r prompt-enhancer-v$npm_package_version.zip dist/",
    "release:package": "npm version patch --no-git-tag-version && npm run package"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.0.287",
    "@types/dotenv": "^6.1.1",
    "@types/node": "^25.1.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "sharp": "^0.34.5",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,html}": [
      "prettier --write"
    ]
  }
}
